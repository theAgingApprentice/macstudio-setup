#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEST="/usr/local/bin"

echo "Copying scripts from ${SCRIPT_DIR} to ${DEST} ..."

count=0
for f in "${SCRIPT_DIR}"/*; do
    [[ -f "${f}" ]] || continue
    [[ -x "${f}" ]] || continue
    name="$(basename "${f}")"
    sudo cp "${f}" "${DEST}/${name}"
    sudo chmod +x "${DEST}/${name}"
    echo "  Copied: ${name}"
    (( count++ )) || true
done

echo "Done — ${count} script(s) installed to ${DEST}"
